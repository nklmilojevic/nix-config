+# Input detection (detect_input) related functions.
+# Repaints the prompt while typing so modules using `detect_input` can react
+# to the command being typed. Only repaints when the first word of the
+# command line changes, to avoid spawning starship on every keystroke.
+function __starship_input_repaint
+    set -l token (commandline --current-buffer | string trim -l | string split -m1 -f1 ' ')
+    if test "$token" != "$__starship_input_last_token"
+        set -g __starship_input_last_token "$token"
+        commandline -f repaint
+    end
+end
+
+function __starship_reset_input --on-event fish_postexec
+    set -g __starship_input_last_token ""
+end
+
+# --user is the default, but listed anyway to make it explicit.
+function enable_input_detection --description 'enable prompt repaint while typing for detect_input modules'
+    bind --user space self-insert __starship_input_repaint
+    bind --user -M insert space self-insert __starship_input_repaint
+    bind --user backspace backward-delete-char __starship_input_repaint
+    bind --user -M insert backspace backward-delete-char __starship_input_repaint
+end
+
+# Erasing a user binding will revert to the preset.
+function disable_input_detection --description 'remove input detection keybindings'
+    bind --user -e space
+    bind --user -M insert -e space
+    bind --user -e backspace
+    bind --user -M insert -e backspace
+end
+
 # Set up the session key that will be used to store logs
 # We don't use `random [min] [max]` because it is unavailable in older versions of fish shell
 set -gx STARSHIP_SESSION_KEY (string sub -s1 -l16 (random)(random)(random)(random)(random)0000000000000000)
