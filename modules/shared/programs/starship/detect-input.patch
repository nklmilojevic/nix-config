+    #[test]
+    fn test_detect_input() -> io::Result<()> {
+        let dir = tempfile::tempdir()?;
+
+        let filename = dir.path().join("config");
+
+        let mut file = File::create(&filename)?;
+        file.write_all(
+            b"
+apiVersion: v1
+clusters: []
+contexts:
+  - context:
+      cluster: test_cluster
+      user: test_user
+    name: test_context
+current-context: test_context
+kind: Config
+preferences: {}
+users: []
+",
+        )?;
+        file.sync_all()?;
+
+        let empty_dir = tempfile::tempdir()?;
+
+        let base_config = toml::toml! {
+            [kubernetes]
+            disabled = false
+            detect_input = ["^(k|kubectl|helm)\\b"]
+        };
+
+        let actual_match = ModuleRenderer::new("kubernetes")
+            .path(empty_dir.path())
+            .env("KUBECONFIG", filename.to_string_lossy().as_ref())
+            .config(base_config.clone())
+            .input("kubectl get pods")
+            .collect();
+
+        let actual_alias = ModuleRenderer::new("kubernetes")
+            .path(empty_dir.path())
+            .env("KUBECONFIG", filename.to_string_lossy().as_ref())
+            .config(base_config.clone())
+            .input("k ")
+            .collect();
+
+        let actual_no_match = ModuleRenderer::new("kubernetes")
+            .path(empty_dir.path())
+            .env("KUBECONFIG", filename.to_string_lossy().as_ref())
+            .config(base_config.clone())
+            .input("ls -la")
+            .collect();
+
+        // Similar prefix must not match ("kubectx" != "kubectl", "kit" != "k")
+        let actual_prefix = ModuleRenderer::new("kubernetes")
+            .path(empty_dir.path())
+            .env("KUBECONFIG", filename.to_string_lossy().as_ref())
+            .config(base_config.clone())
+            .input("kit status")
+            .collect();
+
+        // Fresh prompt: no --input passed at all
+        let actual_no_input = ModuleRenderer::new("kubernetes")
+            .path(empty_dir.path())
+            .env("KUBECONFIG", filename.to_string_lossy().as_ref())
+            .config(base_config)
+            .collect();
+
+        // detect_input matching must reveal the module even when a configured
+        // directory scan does not match (OR semantics)
+        let actual_with_files_config = ModuleRenderer::new("kubernetes")
+            .path(empty_dir.path())
+            .env("KUBECONFIG", filename.to_string_lossy().as_ref())
+            .config(toml::toml! {
+                [kubernetes]
+                disabled = false
+                detect_files = ["k8s.ext"]
+                detect_input = ["^(k|kubectl|helm)\\b"]
+            })
+            .input("helm upgrade")
+            .collect();
+
+        let expected = Some(format!(
+            "{} in ",
+            Color::Cyan.bold().paint("☸ test_context")
+        ));
+
+        assert_eq!(expected, actual_match);
+        assert_eq!(expected, actual_alias);
+        assert_eq!(None, actual_no_match);
+        assert_eq!(None, actual_prefix);
+        assert_eq!(None, actual_no_input);
+        assert_eq!(expected, actual_with_files_config);
+
+        dir.close()
+    }
