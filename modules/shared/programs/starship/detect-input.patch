+    /// Returns true if any of the `detect_input` regular expressions
+    /// match the shell's current command line buffer (passed via `--input`)
+    pub fn detect_input(&self, input_patterns: &[&str]) -> bool {
+        let Some(input) = self.properties.input.as_deref() else {
+            return false;
+        };
+        if input.is_empty() {
+            return false;
+        }
+
+        input_patterns
+            .iter()
+            .any(|pattern| match regex::Regex::new(pattern) {
+                Ok(re) => re.is_match(input),
+                Err(error) => {
+                    log::warn!("Invalid detect_input pattern `{pattern}`: {error}");
+                    false
+                }
+            })
+    }
